{
  "functions": {
    "api/refresh.py":     { "maxDuration": 30 },
    "api/history.py":     { "maxDuration": 30 },
    "api/mcxlive.py":     { "maxDuration": 30 },
    "api/commodities.py": { "maxDuration": 30 },
    "api/mcxprice.py":    { "maxDuration": 15 },
    "api/valuation.py":   { "maxDuration": 15 },
    "api/models.py":      { "maxDuration": 15 },
    "api/analytics.py":   { "maxDuration": 30 },
    "api/cron.py":        { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/refresh",     "destination": "/api/refresh" },
    { "source": "/api/history",     "destination": "/api/history" },
    { "source": "/api/mcxlive",     "destination": "/api/mcxlive" },
    { "source": "/api/commodities", "destination": "/api/commodities" },
    { "source": "/api/mcxprice",    "destination": "/api/mcxprice" },
    { "source": "/api/valuation",   "destination": "/api/valuation" },
    { "source": "/api/models",      "destination": "/api/models" },
    { "source": "/api/analytics",   "destination": "/api/analytics" },
    { "source": "/api/cron",        "destination": "/api/cron" },
    { "source": "/(.*)",            "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron?job=valuation&mode=recent",
      "schedule": "30 19 * * 1-5"
    },
    {
      "path": "/api/cron?job=models&mode=recent",
      "schedule": "45 19 * * 1-5"
    },
    {
      "path": "/api/cron?job=commodity_signals&mode=recent",
      "schedule": "50 19 * * 1-5"
    }
  ]
}
