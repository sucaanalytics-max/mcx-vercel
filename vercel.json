{
  "functions": {
    "api/refresh.py": {
      "maxDuration": 30
    },
    "api/history.py": {
      "maxDuration": 30
    },
    "api/mcxlive.py": {
      "maxDuration": 30
    },
    "api/commodities.py": {
      "maxDuration": 30
    },
    "api/mcxprice.py": {
      "maxDuration": 15
    },
    "api/valuation.py": {
      "maxDuration": 15
    },
    "api/models.py": {
      "maxDuration": 15
    },
    "api/analytics.py": {
      "maxDuration": 30
    },
    "api/cron.py": {
      "maxDuration": 60
    },
    "api/quarterly.py": {
      "maxDuration": 15
    },
    "api/exchange_dashboard.py": {
      "maxDuration": 30
    },
    "api/commodity_dashboard.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/refresh",
      "destination": "/api/refresh"
    },
    {
      "source": "/api/history",
      "destination": "/api/history"
    },
    {
      "source": "/api/mcxlive",
      "destination": "/api/mcxlive"
    },
    {
      "source": "/api/commodities",
      "destination": "/api/commodities"
    },
    {
      "source": "/api/mcxprice",
      "destination": "/api/mcxprice"
    },
    {
      "source": "/api/valuation",
      "destination": "/api/valuation"
    },
    {
      "source": "/api/models",
      "destination": "/api/models"
    },
    {
      "source": "/api/analytics",
      "destination": "/api/analytics"
    },
    {
      "source": "/api/cron",
      "destination": "/api/cron"
    },
    {
      "source": "/api/quarterly",
      "destination": "/api/quarterly"
    },
    {
      "source": "/api/exchange_dashboard",
      "destination": "/api/exchange_dashboard"
    },
    {
      "source": "/api/commodity_dashboard",
      "destination": "/api/commodity_dashboard"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron?job=valuation&mode=recent",
      "schedule": "0 14 * * 1-5"
    },
    {
      "path": "/api/cron?job=models&mode=recent",
      "schedule": "15 14 * * 1-5"
    },
    {
      "path": "/api/cron?job=commodity_signals&mode=recent",
      "schedule": "20 14 * * 1-5"
    },
    {
      "path": "/api/cron?job=margins&mode=recent",
      "schedule": "25 14 * * 1-5"
    },
    {
      "path": "/api/cron?job=momentum&mode=recent",
      "schedule": "10 14 * * 1-5"
    }
  ]
}